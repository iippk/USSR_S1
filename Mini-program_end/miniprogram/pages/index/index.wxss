/* index.wxss - 首页 · Ocean Blue Premium v5.0 */

.index-page {
  padding-bottom: 260rpx;
}

.maintenance-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  border-radius: var(--radius-xl);
  border: 2rpx solid #F59E0B;
}

.mb-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.mb-body {
  flex: 1;
  min-width: 0;
}

.mb-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 2rpx;
}

.mb-msg {
  display: block;
  font-size: 23rpx;
  color: #A16207;
  line-height: 1.4;
}

/* ====== 用户卡片（渐变蓝色）====== */
.user-card {
  position: relative;
  padding: 36rpx 32rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: var(--radius-2xl);
  overflow: hidden;
}

.uc-glass-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
  backdrop-filter: blur(2rpx);
}

.uc-content {
  position: relative;
  z-index: 1;
}

.uc-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-box {
  position: relative;
  flex-shrink: 0;
  width: 100rpx;
  height: 100rpx;
}

.uc-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  animation: ringPulse 3s ease-in-out infinite;
}

@keyframes ringPulse {

  0%,
  100% {
    transform: scale(1);
    opacity: 0.7;
  }

  50% {
    transform: scale(1.08);
    opacity: 0.35;
  }
}

.login-trigger {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(255, 255, 255, 0.4);
}

.login-avatar-icon {
  font-size: 44rpx;
}

.uc-meta {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.uc-name {
  font-size: 34rpx;
  font-weight: 800;
  color: white;
  letter-spacing: -0.01em;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.status-dot-wrap {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #34D399;
  box-shadow: 0 0 10rpx rgba(52, 211, 153, 0.6);
}

.status-dot.online {
  animation: statusBlink 2s ease-in-out infinite;
}

@keyframes statusBlink {

  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.45;
  }
}

.login-hint {
  font-size: 23rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.75);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}

.uc-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 400;
}

.uc-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.btn-logout-mini {
  background: rgba(255, 255, 255, 0.18) !important;
  color: white !important;
  border-radius: var(--radius-full) !important;
  padding: 12rpx 26rpx !important;
  font-size: 22rpx !important;
  font-weight: 600 !important;
  backdrop-filter: blur(10rpx) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.25) !important;
  margin: 0 !important;
  line-height: 1.4 !important;
}

.btn-logout-mini:active {
  background: rgba(255, 255, 255, 0.3) !important;
}

/* 今日目标行 */
.goal-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.12);
  border-radius: var(--radius-lg);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.goal-left {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  flex-shrink: 0;
}

.goal-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
}

.goal-time {
  font-size: 26rpx;
  font-weight: 900;
  color: white;
  font-family: 'SF Mono', monospace;
}

.goal-slash {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
}

.goal-target {
  font-size: 24rpx;
  font-weight: 700;
  color: #93C5FD;
  font-family: 'SF Mono', monospace;
}

.goal-bar-track {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 4rpx;
  overflow: hidden;
}

.goal-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #60A5FA, #93C5FD);
  border-radius: 4rpx;
  transition: width 0.6s ease;
  box-shadow: 0 0 10rpx rgba(96, 165, 250, 0.5);
}

.btn-goal-set {
  padding: 10rpx 10rpx !important;
  background: rgba(255, 255, 255, 0.15) !important;
  color: white !important;
  border-radius: var(--radius-full) !important;
  font-size: 21rpx !important;
  font-weight: 600 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.25) !important;
  /* margin: 0 !important; line-height: 1.3 !important; flex-shrink: 0; */
}

.btn-goal-set:active {
  background: rgba(255, 255, 255, 0.28) !important;
}

/* 目标设置弹窗 */
.goal-modal {
  max-width: 560rpx;
}

.goal-desc {
  display: block;
  font-size: 24rpx;
  color: var(--gray-500);
  margin-bottom: 22rpx;
  text-align: center;
}

.goal-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.goal-opt {
  text-align: center;
  padding: 20rpx 12rpx;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--gray-200);
  transition: all 0.2s ease;
}

.goal-opt:active {
  transform: scale(0.94);
}

.goal-opt.goal-sel {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border-color: var(--blue-400);
  box-shadow: 0 2rpx 10rpx rgba(37, 99, 235, 0.15);
}

.goal-opt-num {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: var(--gray-900);
  margin-bottom: 4rpx;
  font-family: 'SF Mono', monospace;
}

.goal-opt.goal-sel .goal-opt-num {
  color: var(--blue-600);
}

.goal-opt-unit {
  display: block;
  font-size: 19rpx;
  color: var(--gray-400);
}

/* ====== 数据仪表盘 ====== */
.dashboard-section {
  background: white;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--gray-100);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.ds-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
}

.ds-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--gray-900);
}

.refresh-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: var(--blue-50);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--blue-100);
  transition: all 0.2s ease;
}

.refresh-chip:active {
  transform: scale(0.94);
  background: var(--blue-100);
}

.refresh-icon {
  font-size: 24rpx;
  color: var(--blue-500);
}

refresh-chip text {
  font-size: 21rpx;
  color: var(--blue-600);
  font-weight: 600;
}

/* 四格统计卡片 */
.stats-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.stat-card {
  text-align: center;
  padding: 22rpx 12rpx 18rpx;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--gray-100);
  transition: all 0.25s ease;
}

.stat-card:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-sm);
}

.sc-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 10rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.sc-icon-wrap.total {
  background: linear-gradient(135deg, var(--blue-50), var(--blue-100));
}

.sc-icon-wrap.avail {
  background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
}

.sc-icon-wrap.using {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
}

.sc-icon-wrap.reserved {
  background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
}

.sc-icon-wrap.fix {
  background: linear-gradient(135deg, #FEF2F2, #FEE2E2);
}

.sc-icon {
  font-size: 26rpx;
}

.sc-num {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  color: var(--gray-900);
  margin-bottom: 4rpx;
  line-height: 1.1;
}

.text-primary {
  color: var(--emerald) !important;
}

.text-warn {
  color: #EF4444 !important;
}

.sc-label {
  font-size: 20rpx;
  color: var(--gray-400);
  font-weight: 500;
}

/* 座位状态可视化 */
.seat-status-viz {
  display: flex;
  height: 40rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-top: 18rpx;
  border: 1rpx solid var(--gray-200);
}

.ssv-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: flex 0.5s ease;
}

.ssv-text {
  font-size: 19rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.2);
}

.ssv-free {
  background: linear-gradient(135deg, #10B981, #059669);
}

.ssv-busy {
  background: linear-gradient(135deg, var(--blue-500), var(--blue-600));
}

.ssv-rsv {
  background: linear-gradient(135deg, var(--amber), #D97706);
}

.ssv-fix {
  background: linear-gradient(135deg, #CBD5E1, #94A3B8);
}

.ssv-empty-tip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gray-100);
  border-radius: var(--radius-lg);
}

.ssv-empty-tip .ssv-text {
  color: var(--gray-400);
  text-shadow: none;
  font-size: 21rpx;
}

/* ====== 功能导航网格 ====== */
.features-section {
  background: white;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--gray-100);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.fs-header {
  margin-bottom: 20rpx;
}

.fs-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--gray-900);
}

.features-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.feature-card {
  padding: 24rpx 20rpx;
  background: var(--gray-50);
  border-radius: var(--radius-xl);
  border: 1rpx solid var(--gray-100);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--blue-300), transparent);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.feature-card:active {
  transform: scale(0.96) translateY(-2rpx);
  box-shadow: var(--shadow-md);
  background: white;
}

.feature-card:active::before {
  opacity: 1;
}

.fc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.fc-icon-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.15);
}

.fc-icon {
  font-size: 30rpx;
}

.fc-arrow {
  font-size: 26rpx;
  color: var(--gray-300);
  font-weight: 300;
  transition: all 0.2s ease;
}

.feature-card:active .fc-arrow {
  color: var(--blue-500);
  transform: translateX(4rpx);
}

.fc-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: 4rpx;
}

.fc-desc {
  display: block;
  font-size: 21rpx;
  color: var(--gray-400);
}

/* ====== 在线人数卡片 ====== */
.online-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}

.oc-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.online-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--emerald);
  animation: onlinePulse 2s ease-in-out infinite;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.4);
}

@keyframes onlinePulse {

  0%,
  100% {
    box-shadow: 0 0 8rpx rgba(16, 185, 129, 0.3);
  }

  50% {
    box-shadow: 0 0 20rpx rgba(16, 185, 129, 0.55);
  }
}

.oc-label {
  font-size: 25rpx;
  color: var(--gray-600);
  font-weight: 500;
}

.oc-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.oc-num {
  font-size: 42rpx;
  font-weight: 900;
  color: var(--blue-600);
}

.oc-unit {
  font-size: 23rpx;
  color: var(--gray-400);
  font-weight: 500;
}

.announcement-section {
  background: #fff;
  border-radius: var(--radius-2xl);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.ann-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ann-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ann-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gray-800);
}

.ann-count-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--blue-600);
  background: var(--blue-50);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--blue-100);
}

.ann-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: var(--blue-500);
  font-weight: 500;
}

.ann-arrow {
  font-size: 30rpx;
  color: var(--blue-400);
  flex-shrink: 0;
}

.ann-latest {
  background: linear-gradient(135deg, #EFF6FF, #F0F9FF);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  border: 1rpx solid #DBEAFE;
  position: relative;
}

.ann-latest-tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 600;
  color: #B45309;
  background: #FEF3C7;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  margin-bottom: 12rpx;
  border: 1rpx solid #FDE68A;
}

.ann-latest-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gray-900);
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.ann-latest-content {
  display: block;
  font-size: 25rpx;
  color: var(--gray-600);
  line-height: 1.7;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 14rpx;
}

.ann-latest-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ann-latest-time {
  font-size: 22rpx;
  color: var(--gray-400);
}

.ann-latest-hint {
  font-size: 22rpx;
  color: var(--blue-500);
  font-weight: 500;
}

.lang-switch-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  flex-shrink: 0;
}

.lang-switch-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.lsb-icon {
  font-size: 22rpx;
}

.lsb-text {
  font-size: 20rpx;
  font-weight: 700;
  color: white;
}

.lang-modal {
  max-width: 520rpx;
}

.lang-options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.lang-opt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 20rpx;
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--gray-200);
  transition: all 0.2s ease;
}

.lang-opt:active {
  transform: scale(0.96);
}

.lang-opt.lang-sel {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border-color: var(--blue-400);
  box-shadow: 0 2rpx 10rpx rgba(37, 99, 235, 0.15);
}

.lo-label {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--gray-900);
  margin-bottom: 4rpx;
}

.lang-opt.lang-sel .lo-label {
  color: var(--blue-600);
}

.lo-desc {
  font-size: 22rpx;
  color: var(--gray-400);
}