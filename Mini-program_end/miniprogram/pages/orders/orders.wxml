<!--orders.wxml - 订单管理 · 淘宝式卡片布局 · Ocean Blue Design-->
<view class="container">
  <view class="oc-head">
    <text class="section-title-inline">{{i18n.title}}</text>
    <view class="refresh-chip" bindtap="loadOrders"><text class="refresh-icon">↻</text><text>{{i18n.refresh}}</text></view>
  </view>

  <view class="loading-box" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view><text>{{i18n.loading}}</text>
  </view>

  <view wx:else>
    <!-- 空状态 -->
    <view wx:if="{{orders.length === 0}}" class="empty-orders">
      <text class="empty-icon">📋</text>
      <text class="empty-text">{{i18n.noOrders}}</text>
      <text class="empty-sub">{{i18n.noOrdersTip}}</text>
      <button class="btn-go-seat" bindtap="goToSeat">{{i18n.goReserve}}</button>
    </view>

    <!-- 订单列表 - 淘宝式卡片 -->
    <scroll-view scroll-y="{{true}}" style="max-height:1200rpx;" wx:if="{{orders.length > 0}}">
      <view class="order-list">
        <view
          wx:for="{{orders}}"
          wx:key="_id"
          class="order-card {{item.status === '进行中' ? 'oc-active' : item.status === '已完成' ? 'oc-done' : ''}}"
        >
          <!-- ====== 顶栏：店铺名 + 状态 ====== -->
          <view class="oc-topbar">
            <view class="oc-shop">
              <text class="shop-icon">🪑</text>
              <text class="shop-name">{{i18n.shopName}}</text>
              <text class="shop-arrow">›</text>
            </view>
            <text class="oc-status {{getStatusClass(item.status)}}">{{item.status}}</text>
          </view>

          <!-- ====== 商品主体区 ====== -->
          <view class="oc-product">
            <!-- 左侧商品图 -->
            <view class="oc-thumb">
              <text class="thumb-emoji">📚</text>
            </view>

            <!-- 右侧详情 -->
            <view class="oc-detail">
              <text class="oc-pname">{{i18n.productName}}</text>
              <text class="oc-specs">{{item.planType}} × {{item.quantity}}{{item.unitText || (item.planType === 'hour' ? i18n.hour : item.planType === 'day' ? i18n.day : i18n.week)}}</text>
            </view>

            <!-- 右侧金额区 -->
            <view class="oc-price-col">
              <text class="oc-price-label">{{i18n.actualPay}}</text>
              <view class="oc-price-row">
                <text class="oc-currency">¥</text>
                <text class="oc-price-num">{{item.finalPrice || item.totalPrice}}</text>
              </view>
              <text class="oc-original" wx:if="{{item.couponUsed && item.couponDiscount > 0}}">¥{{item.totalPrice}}</text>
            </view>
          </view>

          <!-- ====== 信息明细行 ====== -->
          <view class="oc-info-row">
            <view class="info-cell">
              <text class="info-dot seat"></text>
              <text class="info-lbl">{{i18n.seatNumber}}</text>
              <text class="info-val highlight">{{item.seatNumber}}</text>
            </view>
            <view class="info-cell">
              <text class="info-dot time"></text>
              <text class="info-lbl">{{i18n.orderTime}}</text>
              <text class="info-val">{{item.createdAtText || item.formattedDate}}</text>
            </view>
          </view>
          <view class="oc-info-row">
            <view class="info-cell">
              <text class="info-dot expire"></text>
              <text class="info-lbl">{{i18n.expireTime}}</text>
              <text class="info-val warn">{{item.expireAtText || item.formattedExpireAt || i18n.notSet}}</text>
            </view>
            <view class="info-cell">
              <text class="info-dot dur"></text>
              <text class="info-lbl">{{i18n.studyTime}}</text>
              <text class="info-val">{{item.formattedDuration}}</text>
            </view>     
          </view>

          <!-- 优惠券使用提示 -->
          <view class="oc-coupon-tag" wx:if="{{item.couponUsed && item.couponDiscount > 0}}">
            <text class="coupon-tag-icon">🎫</text>
            <text>{{i18n.couponApplied}}{{item.couponDiscount}}</text>
          </view>

          <!-- ====== 底栏：操作按钮 ====== -->
          <view class="oc-bottom">
            <text class="oc-total-lbl">{{i18n.totalItems}}</text>
            <view class="oc-btns">
              <block wx:if="{{item.status === '进行中'}}">
                <button class="oc-btn oc-btn-outline" bindtap="cancelOrder" data-id="{{item._id}}">{{i18n.cancelOrder}}</button>
                <button class="oc-btn oc-btn-primary" bindtap="goToStudyForExtend" data-id="{{item._id}}" data-seat-id="{{item.seatId}}">{{i18n.extendTime}}</button>
              </block>
              <block wx:elif="{{item.status === '已完成'}}">
                <button class="oc-btn oc-btn-outline" catchtap="">{{i18n.reorder}}</button>
              </block>
              <block wx:elif="{{item.status === '已取消'}}">
                <button class="oc-btn oc-btn-outline" catchtap="">{{i18n.deleteRecord}}</button>
              </block>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
