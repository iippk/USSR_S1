/* orders.wxss - 订单管理 · 淘宝式卡片布局 · Ocean Blue Enterprise */

/* ====== 头部 ====== */
.oc-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.refresh-chip {
  display: flex; align-items: center; gap: 6rpx;
  padding: 10rpx 20rpx; background: #F1F5F9; border-radius: var(--radius-full);
  font-size: 22rpx; color: #64748B;
}
.refresh-icon { font-size: 24rpx; }

.loading-box { display: flex; flex-direction: column; align-items: center; height: 300rpx; gap: 16rpx; }

/* 空状态 */
.empty-orders { text-align: center; padding: 60rpx 20rpx; }
.empty-orders .empty-icon { font-size: 72rpx; margin-bottom: 20rpx; opacity: 0.45; }
.empty-text { font-size: 30rpx; font-weight: 600; color: #334155; display: block; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #94A3B8; display: block; margin-bottom: 28rpx; }
.btn-go-seat {
  background: linear-gradient(135deg, #2563EB, #1D4ED8) !important;
  color: white !important; border: none !important;
  border-radius: var(--radius-full) !important; padding: 18rpx 44rpx !important;
  font-size: 26rpx !important; font-weight: 600 !important;
  box-shadow: 0 4rpx 16rpx rgba(37,99,235,0.28) !important;
}

/* ====== 订单列表 ====== */
.order-list { display: flex; flex-direction: column; gap: 18rpx; }

/* ====== 单张订单卡片（淘宝式）====== */
.order-card {
  background: white; border-radius: var(--radius-xl);
  overflow: hidden; box-shadow: var(--shadow-md);
  border: 1rpx solid #E2E8F0; transition: all 0.2s ease;
}
.order-card:active { transform: scale(0.99); }

/* 进行中高亮 */
.order-card.oc-active {
  border-color: rgba(16,185,129,0.25);
  box-shadow: 0 2rpx 16rpx rgba(16,185,129,0.08), var(--shadow-md);
}

/* 已完成 */
.order-card.oc-done { opacity: 0.85; }

/* ---- 顶栏：店铺名 + 状态 ---- */
.oc-topbar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 26rpx; background: #FAFBFC;
  border-bottom: 1rpx solid #F1F5F9;
}
.oc-shop { display: flex; align-items: center; gap: 8rpx; }
.shop-icon { font-size: 28rpx; }
.shop-name { font-size: 27rpx; font-weight: 700; color: #0F172A; }
.shop-arrow { font-size: 24rpx; color: #94A3B8; font-weight: 300; }

.oc-status {
  font-size: 23rpx; font-weight: 700; padding: 5rpx 14rpx;
  border-radius: var(--radius-full); letter-spacing: 0.02em;
}
.oc-status.ongoing { background: rgba(16,185,129,0.1); color: #059669; }
.oc-status.finished { background: rgba(100,116,139,0.08); color: #475569; }
.oc-status.cancelled { background: rgba(239,68,68,0.06); color: #DC2626; }

/* ---- 商品主体区 ---- */
.oc-product {
  display: flex; align-items: flex-start; gap: 18rpx;
  padding: 22rpx 26rpx;
}

/* 左侧缩略图 */
.oc-thumb {
  width: 120rpx; height: 120rpx; flex-shrink: 0;
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
  border-radius: var(--radius-lg);
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid rgba(37,99,235,0.12);
}
.thumb-emoji { font-size: 52rpx; }

/* 中间详情 */
.oc-detail { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.oc-pname {
  font-size: 28rpx; font-weight: 700; color: #0F172A;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  letter-spacing: -0.01em;
}
.oc-specs {
  font-size: 23rpx; color: #64748B;
  background: #F8FAFC; display: inline-block; padding: 4rpx 12rpx;
  border-radius: var(--radius-sm); align-self: flex-start;
}

/* 右侧金额列 */
.oc-price-col {
  flex-shrink: 0; text-align: right;
  display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx;
}
.oc-price-label { font-size: 21rpx; color: #94A3B8; }
.oc-price-row { display: flex; align-items: baseline; }
.oc-currency { font-size: 24rpx; font-weight: 700; color: #EF4444; }
.oc-price-num {
  font-size: 38rpx; font-weight: 900; color: #EF4444;
  font-family: 'SF Mono', monospace; line-height: 1;
}
.oc-original {
  font-size: 20rpx; color: #CBD5E1; text-decoration: line-through;
}

/* ---- 信息明细行 ---- */
.oc-info-row {
  display: flex; gap: 0; padding: 12rpx 26rpx 0;
}
.info-cell {
  flex: 1; display: flex; align-items: center; gap: 6rpx;
  padding: 10rpx 14rpx; background: #FAFBFC; border-radius: var(--radius-sm);
  margin-right: 12rpx;
}
.info-cell:last-child { margin-right: 0; }

.info-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0;
}
.info-dot.seat { background: #2563EB; }
.info-dot.time { background: #64748B; }
.info-dot.expire { background: #F59E0B; }
.info-dot.dur { background: #10B981; }

.info-lbl { font-size: 20rpx; color: #94A3B8; flex-shrink: 0; }
.info-val { font-size: 22rpx; font-weight: 600; color: #334155; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.info-val.highlight { color: #2563EB; font-weight: 700; font-family: 'SF Mono', monospace; }
.info-val.warn { color: #D97706; font-weight: 600; }

/* ---- 优惠券标签 ---- */
.oc-coupon-tag {
  display: flex; align-items: center; gap: 8rpx;
  margin: 12rpx 26rpx 0; padding: 10rpx 16rpx;
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
  border-radius: var(--radius-sm); border-left: 3rpx solid #F97316;
}
.coupon-tag-icon { font-size: 22rpx; flex-shrink: 0; }
.oc-coupon-tag text:last-child { font-size: 21rpx; color: #9A3412; font-weight: 500; }

/* ---- 底栏：合计 + 操作按钮 ---- */
.oc-bottom {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 26rpx; border-top: 1rpx dashed #E2E8F0;
  margin-top: 12rpx;
}
.oc-total-wrap { display: flex; align-items: baseline; gap: 6rpx; }
.oc-total-lbl { font-size: 22rpx; color: #94A3B8; }
.oc-total-txt { font-size: 23rpx; color: #64748B; font-weight: 500; }
.oc-total-price {
  font-size: 30rpx; font-weight: 900; color: #EF4444;
  font-family: 'SF Mono', monospace;
}

.oc-btns { display: flex; gap: 14rpx; }

/* 按钮样式 */
.oc-btn {
  padding: 13rpx 28rpx !important; font-size: 23rpx !important;
  border-radius: var(--radius-full) !important;
  font-weight: 600 !important; line-height: 1.35 !important;
  transition: all 0.2s ease !important;
}
.oc-btn:active { transform: scale(0.95) !important; }

.oc-btn-outline {
  background: white !important; color: #475569 !important;
  border: 1.5rpx solid #CBD5E1 !important;
  box-shadow: none !important;
}
.oc-btn-outline:active { background: #F8FAFC !important; }

.oc-btn-primary {
  background: linear-gradient(135deg, #2563EB, #1D4ED8) !important;
  color: white !important; border: none !important;
  box-shadow: 0 3rpx 12rpx rgba(37,99,235,0.25) !important;
}
