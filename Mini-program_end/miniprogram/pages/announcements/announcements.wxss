.ann-page {
  min-height: 100vh;
  background: #F8FAFC;
}

.ann-main {
  height: 100vh;
}

/* ====== 文章内容区 ====== */
.ann-article {
  background: white;
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 16rpx;
}

.aa-badge-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.aa-pin {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #B45309;
  background: #FEF3C7;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #FDE68A;
}

.aa-type-tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #1D4ED8;
  background: #EFF6FF;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #BFDBFE;
}

.aa-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #0F172A;
  line-height: 1.35;
  letter-spacing: -0.02em;
  margin-bottom: 16rpx;
}

.aa-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.aa-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.aa-divider {
  height: 2rpx;
  background: linear-gradient(90deg, #E2E8F0, #F1F5F9, #E2E8F0);
  margin-bottom: 28rpx;
  border-radius: 1rpx;
}

.aa-content {
  font-size: 30rpx;
  color: #334155;
  line-height: 2;
  word-break: break-all;
  white-space: pre-wrap;
  letter-spacing: 0.02em;
}

/* ====== 更多公告区 ====== */
.ann-others {
  padding: 0 24rpx 40rpx;
}

.ao-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx 16rpx;
}

.ao-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
}

.ao-count {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.ao-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ao-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F1F5F9;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.ao-card::after {
  content: '';
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #CBD5E1;
  border-right: 3rpx solid #CBD5E1;
  transform: translateY(-50%) rotate(45deg);
  transition: all 0.2s ease;
}

.ao-card:active {
  transform: scale(0.98);
  background: #F8FAFC;
  box-shadow: 0 4rpx 20rpx rgba(37, 99, 235, 0.08);
  border-color: #BFDBFE;
}

.ao-card:active::after {
  border-color: #2563EB;
}

.aoc-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  padding-right: 36rpx;
}

.aoc-pin {
  font-size: 22rpx;
  flex-shrink: 0;
}

.aoc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.aoc-preview {
  display: block;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
  padding-right: 36rpx;
}

.aoc-time {
  display: block;
  font-size: 22rpx;
  color: #94A3B8;
}

/* ====== 空状态 ====== */
.ann-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  gap: 16rpx;
}

.ae-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.ae-text {
  font-size: 28rpx;
  color: #94A3B8;
}
