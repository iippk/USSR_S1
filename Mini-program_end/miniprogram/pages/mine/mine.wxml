  <!-- 功能介绍 -->
  <view class="info-card card-solid fade-up" style="animation-delay: 0.22s;">
    <view class="ic-header"><text class="ic-title">ℹ️ {{i18n.aboutApp}}</text></view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-emoji">🏢</text>
        <view class="info-body">
          <text class="info-name">{{i18n.appName}}</text>
          <text class="info-desc">{{i18n.appDesc}}</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-emoji">⚡</text>
        <view class="info-body">
          <text class="info-name">{{i18n.realtimeMonitor}}</text>
          <text class="info-desc">{{i18n.realtimeMonitorDesc}}</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-emoji">🔒</text>
        <view class="info-body">
          <text class="info-name">{{i18n.securePayment}}</text>
          <text class="info-desc">{{i18n.securePaymentDesc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="app-footer">
    <text class="footer-brand">{{i18n.footerBrand}}</text>
    <text class="footer-ver">{{i18n.footerPowered}}</text>
  </view>

  <!-- 昵称修改弹窗 -->
  <view class="modal-overlay" wx:if="{{showNicknameDialog}}" bindtap="onNicknameOverlayTap">
    <view class="modal-content nick-modal" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">✏️ {{i18n.editNickname}}</text>
        <view class="modal-close" bindtap="closeNicknameDialog">×</view>
      </view>
      <view class="modal-body">
        <input class="nick-input ifl-input" value="{{newNickname}}" placeholder="{{i18n.nicknamePlaceholder}}" maxlength="20" bindinput="onNicknameInput" />
        <text class="nick-len">{{newNickname.length}}/20</text>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeNicknameDialog">{{i18n.cancel}}</button>
        <button class="btn-confirm" style="background: linear-gradient(135deg, #7C3AED, #6D28D9) !important; box-shadow: 0 4rpx 16rpx rgba(124,58,237,0.28) !important;" bindtap="updateNickname">{{i18n.save}}</button>
      </view>
    </view>
  </view>

  <!-- 头像选择弹窗 -->
  <view class="modal-overlay" wx:if="{{showAvatarDialog}}" bindtap="onAvatarOverlayTap">
    <view class="modal-content avatar-modal" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">📷 {{i18n.changeAvatar}}</text>
        <view class="modal-close" bindtap="closeAvatarDialog">×</view>
      </view>
      <view class="modal-body">
        <view class="av-options">
          <view class="av-opt" bindtap="chooseAvatarFromAlbum">
            <text class="av-opt-icon">🖼️</text>
            <text>{{i18n.fromAlbum}}</text>
          </view>
          <view class="av-opt" bindtap="useDefaultAvatar">
            <text class="av-opt-icon">😊</text>
            <text>{{i18n.useDefault}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
