<!--mine.wxml - 个人中心 · Ocean Blue Premium v5.0-->
<view class="container mine-page">
  <!-- 用户卡片 - 紫蓝渐变 -->
  <view class="card-gradient-violet user-card fade-up" wx:if="{{userInfo}}">
    <view class="uc-glass"></view>
    <view class="uc-content">
      <view class="uc-top">
        <view class="avatar-box" bindtap="chooseAvatar">
          <image class="uc-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
          <view class="avatar-ring"></view>
          <view class="avatar-edit">✎</view>
        </view>
        <view class="uc-meta">
          <view class="name-row">
            <text class="uc-name">{{userInfo.nickName}}</text>
            <view class="edit-name-btn" bindtap="showNicknameDialog">{{i18n.edit}}</view>
          </view>
          <text class="uc-sub">ID: {{userInfo._openid ? userInfo._openid.substring(0, 8) : '-'}}...</text>
        </view>

        <!-- 累计学习次数 - 内嵌用户卡片右侧 -->
        <view class="study-count-inline">
          <text class="sci-icon">📚</text>
          <view class="sci-detail">
            <text class="sci-num font-mono">{{studyCount}}</text>
            <text class="sci-lbl">{{i18n.totalStudy}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 登录引导 -->
  <view class="login-card card-solid fade-up" wx:else>
    <view class="login-hero">
      <text class="login-icon">👤</text>
      <text class="login-title">{{i18n.loginToViewMore}}</text>
      <text class="login-desc">{{i18n.loginDesc}}</text>
      <button class="btn-login-action" bindtap="handleLogin">{{i18n.loginNow}}</button>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-entry fade-up" style="animation-delay: 0.12s;" bindtap="goToOrders">
    <view class="qe-left">
      <view class="qe-icon-circle blue"><text class="qe-icon-text">📋</text></view>
      <view class="qe-text-group">
        <text class="qe-text">{{i18n.myOrders}}</text>
        <text class="qe-desc">{{i18n.myOrdersDesc}}</text>
      </view>
    </view>
    <text class="qe-arrow">›</text>
  </view>

  <view class="quick-entry fade-up" style="animation-delay: 0.14s;" bindtap="goToCoupons">
    <view class="qe-left">
      <view class="qe-icon-circle amber"><text class="qe-icon-text">🎫</text></view>
      <view class="qe-text-group">
        <text class="qe-text">{{i18n.myCoupons}}</text>
        <text class="qe-desc">{{couponCount > 0 ? couponCount + i18n.couponAvailable : i18n.noCoupon}}</text>
      </view>
    </view>
    <text class="qe-arrow">›</text>
  </view>

  <!-- 最近自习记录（分页） -->
  <!-- <view class="rec-card card-solid fade-up" style="animation-delay: 0.18s;">
    <view class="rec-header">
      <text class="rec-title">📝 最近记录</text>
