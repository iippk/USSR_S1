    <view class="empty-rec" wx:elif="{{!isLoading && studyRecords.length === 0}}">
      <text class="empty-icon">📝</text><text class="empty-text">暂无学习记录</text><text class="empty-tip">开始学习后将自动记录</text>
    </view>

