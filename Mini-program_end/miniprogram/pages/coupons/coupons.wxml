<!--coupons.wxml - 优惠券 · Ocean Blue Design (Cyan Theme)-->
<view class="container">
  <!-- 头部卡片 - 淡蓝渐变 -->
  <view class="card-gradient-cyan coupon-header">
    <text class="ch-title">{{i18n.title}}</text>
    <text class="ch-sub">{{i18n.subtitle}}</text>
    <view class="ch-stats">
      <view class="ch-stat-item">
        <text class="cs-num">{{couponCount}}</text>
        <text class="cs-lbl">{{i18n.availableCount}}</text>
      </view>
      <view class="ch-divider"></view>
      <view class="ch-stat-item">
        <text class="cs-num">{{usedCount}}</text>
        <text class="cs-lbl">{{i18n.usedCount}}</text>
      </view>
      <view class="ch-divider"></view>
      <view class="ch-stat-item">
        <text class="cs-num">{{expiredCount}}</text>
        <text class="cs-lbl">{{i18n.expiredCount}}</text>
      </view>
    </view>
  </view>

  <!-- 领取中心 -->
  <view class="pool-section" wx:if="{{poolCoupons.length > 0}}">
    <view class="pool-header">
      <text class="pool-title">{{i18n.claimCenter}}</text>
      <text class="pool-sub">{{i18n.claimCenterSub}}</text>
    </view>
    <view class="pool-grid">
      <view
        wx:for="{{poolCoupons}}"
        wx:key="type"
        class="pool-card"
      >
        <view class="pool-left">
          <text class="pool-currency">¥</text>
          <text class="pool-amount">{{item.discountAmount}}</text>
          <text class="pool-condition">{{item.type}}</text>
        </view>
        <view class="pool-mid">
          <text class="pool-name">{{item.type}}</text>
          <text class="pool-scope">{{i18n.universal}}</text>
          <text class="pool-date">{{i18n.validUntil}} {{item.formattedExpireDate}}</text>
          <text class="pool-stock">{{i18n.remaining}} {{item.count}} {{i18n.stockUnit}}</text>
        </view>
        <view class="pool-right">
          <view class="pool-claim-btn" data-type="{{item.type}}" bindtap="claimCoupon">
            <text>{{i18n.claim}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-switch cp-tab">
    <view class="tab-btn {{currentTab === 'available' ? 'tab-on' : ''}}" data-tab="available" bindtap="switchTab"><text>{{i18n.available}}</text></view>
    <view class="tab-btn {{currentTab === 'used' ? 'tab-on' : ''}}" data-tab="used" bindtap="switchTab"><text>{{i18n.used}}</text></view>
    <view class="tab-btn {{currentTab === 'expired' ? 'tab-on' : ''}}" data-tab="expired" bindtap="switchTab"><text>{{i18n.expired}}</text></view>
  </view>

  <!-- 优惠券列表 -->
  <view class="card-solid coupon-list-card">
    <view class="loading-box" wx:if="{{isLoading}}">
      <view class="loading-spinner"></view><text>{{i18n.loading}}</text>
    </view>

    <view wx:else>
      <view wx:if="{{filteredCoupons.length === 0}}" class="empty-coupons">
        <text class="empty-icon">🎫</text>
        <text class="empty-text">{{getEmptyText()}}</text>
        <text class="empty-sub">{{i18n.getMoreCoupons}}</text>
      </view>

      <view class="cp-grid" wx:if="{{filteredCoupons.length > 0}}">
        <view
          wx:for="{{filteredCoupons}}"
          wx:key="_id"
          class="cp-card {{item.isExpired ? 'cp-expired' : item.status === 'used' ? 'cp-used' : ''}}"
        >
          <!-- 左侧金额区 -->
          <view class="cp-left-part">
            <text class="cp-currency">¥</text>
            <text class="cp-amount">{{item.discountAmount}}</text>
            <text class="cp-condition">{{item.type}}</text>
          </view>

          <!-- 中间锯齿分割 -->
          <view class="cp-divider">
            <view class="cp-dash-line"></view>
          </view>

          <!-- 右侧信息区 -->
          <view class="cp-right-part">
            <view class="cr-top">
              <text class="cp-name">{{item.name || i18n.couponName}}</text>
              <view class="cp-status-badge {{item.status === 'available' && !item.isExpired ? 'sb-active' : item.status === 'used' ? 'sb-used' : 'sb-expired'}}">
                {{item.status === 'available' && !item.isExpired ? i18n.available : item.status === 'used' ? i18n.used : i18n.expired}}
              </view>
            </view>
            <text class="cp-scope">{{i18n.seatAvailable}}</text>
            <text class="cp-date">{{item.formattedExpireDate || i18n.longTermValid}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="coupon-tips" wx:if="{{!isLoading && filteredCoupons.length > 0}}">
    <text class="tips-icon">💡</text>
    <text class="tips-text">{{i18n.couponTip}}</text>
  </view>
</view>
