/* custom-tab-bar/index.wxss - 自定义底部导航栏 · Ocean Blue Premium */

.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  pointer-events: none;
}

.tab-bar-bg {
  position: relative;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(30rpx) saturate(180%);
  -webkit-backdrop-filter: blur(30rpx) saturate(180%);
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  box-shadow:
    0 -4rpx 24rpx rgba(15, 23, 42, 0.06),
    0 -2rpx 8rpx rgba(15, 23, 42, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  pointer-events: auto;
}

/* ====== 顶部指示器轨道 ====== */
.indicator-track {
  position: relative;
  height: 6rpx;
  padding: 0 40rpx;
  margin-bottom: 8rpx;
}

.indicator-dot {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #2563EB, #60A5FA);
  border-radius: 3rpx;
  transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.4);
}

/* ====== Tab项布局 ====== */
.tab-items {
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding: 10rpx 0 16rpx;
  position: relative;
}

/* 单个Tab */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 120rpx;
  padding: 8rpx 16rpx 6rpx;
  border-radius: 28rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.tab-item:active {
  transform: scale(0.88);
}

.tab-item.animating {
  animation: tabSpring 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes tabSpring {
  0% { transform: scale(1); }
  40% { transform: scale(1.25); }
  70% { transform: scale(0.92); }
  100% { transform: scale(1); }
}

/* 图标容器 */
.icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 42rpx;
  line-height: 1;
  position: relative;
  z-index: 2;
  transition: all 0.25s ease;
  filter: grayscale(100%) opacity(0.55);
}

.tab-item.active .tab-icon {
  filter: none;
  opacity: 1;
  transform: translateY(-2rpx);
}

/* 激活光晕 */
.icon-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 64rpx;
  height: 32rpx;
  margin-left: -32rpx;
  margin-top: -14rpx;
  background: radial-gradient(ellipse at center, rgba(37, 99, 235, 0.22), transparent 70%);
  border-radius: 50%;
  animation: glowPulse 2s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

/* 点击波纹效果 */
.ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80rpx;
  height: 80rpx;
  margin-left: -40rpx;
  margin-top: -40rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.18), transparent 70%);
  animation: rippleOut 0.6s ease-out forwards;
  z-index: 1;
}

@keyframes rippleOut {
  0% { transform: scale(0.3); opacity: 1; }
  100% { transform: scale(2); opacity: 0; }
}

/* 文字样式 */
.tab-text {
  font-size: 19rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
  line-height: 1.2;
  transition: all 0.25s ease;
  color: #94A3B8;
}

.tab-item.active .tab-text {
  color: #2563EB;
  font-weight: 700;
  font-size: 20rpx;
}

/* 选中指示圆点 */
.select-indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563EB, #60A5FA);
  margin-top: 2rpx;
  box-shadow: 0 0 6rpx rgba(37, 99, 235, 0.45);
  animation: dotPopIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes dotPopIn {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* 安全区 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 20rpx;
}
